# App
APP_BASE_URL=https://yourdomain.com
NODE_ENV=development
# Domain Caddy melayani TLS-nya (dipakai Caddyfile sebagai {$SITE_ADDRESS}). Tanpa skema, mis:
#   SITE_ADDRESS=domainanda.com
SITE_ADDRESS=yourdomain.com

# Database
DATABASE_URL=postgresql://user:pass@host:5432/ebook

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# WAHA (3rd-party managed service — public HTTPS only)
# MUST start with https:// — the app refuses to start otherwise.
WAHA_BASE_URL=https://your-instance.waha-provider.example
WAHA_API_KEY=
WAHA_SESSION=default
# HMAC key for the inbound webhook /api/webhooks/waha (challenge proof videos).
# Set the SAME value as the WAHA session webhook's hmac.key. Required to accept inbound (§21.6).
# Generate one (run on the server, don't paste it anywhere else):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WAHA_WEBHOOK_SECRET=
# Debug: set to 1/true to log every outbound WAHA send ([waha-send] chatId/lid/response).
# On by default only in development; set this to see the logs in production. Off when unset.
WAHA_LOG_SENDS=

# Files (local, private — MUST be outside the web root / public dir)
EBOOK_FILES_DIR=/data/ebooks
# Inbound challenge proof videos (private volume; defaults to /data/challenge-media)
CHALLENGE_MEDIA_DIR=/data/challenge-media

# Security
# CRON_SECRET dipakai HANYA via header `x-cron-secret` (query ?secret= sudah dihapus).
ADMIN_TOKEN=
CRON_SECRET=

# Email fallback (D14, §23) — opsional; mati kecuali EMAIL_FALLBACK_ENABLED=true + kredensial diisi.
EMAIL_FALLBACK_ENABLED=false
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=

# Fonnte (engine WhatsApp alternatif, D15, §24) — opsional; hanya perlu jika engine aktif = 'fonnte'.
FONNTE_TOKEN=
# Secret di URL webhook inbound Fonnte: /api/webhooks/fonnte?token=<ini> (Fonnte tak punya HMAC).
FONNTE_WEBHOOK_SECRET=

# Docker Compose (postgres service)
POSTGRES_PASSWORD=
