// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  priceIdr    Int // IDR, no decimals (e.g. 100000)
  filePath    String // path to the e-book RELATIVE to EBOOK_FILES_DIR, e.g. "my-ebook.pdf"
  fileName    String // filename shown to the buyer, e.g. "my-ebook.pdf"
  mimeType    String   @default("application/pdf")
  isActive    Boolean  @default(true)
  linkMessageTemplate String? // D16 (§25): editable WA message carrying the download link ({{name}}/{{product}}/{{link}})
  programName  String? // operator-facing program label, e.g. "Diet90"
  salesStartAt DateTime? // sales window start (WIB); null = no lower bound
  salesEndAt   DateTime? // sales window end (inclusive, WIB); after this, checkout is suspended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  attachments ProductAttachment[]
  challenge   Challenge?
}

model ProductAttachment {
  id        String   @id @default(cuid())
  productId String
  filePath  String // relative to EBOOK_FILES_DIR, private (like the e-book)
  fileName  String // buyer-facing name
  mimeType  String   @default("application/pdf")
  sizeBytes Int?
  sortOrder Int      @default(0) // delivery order after the main e-book
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  whatsapp  String // normalized digits, no '+', e.g. "628123456789"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  challengeParticipations ChallengeParticipant[]

  @@unique([email, whatsapp])
  @@index([whatsapp])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

model Order {
  id                    String      @id @default(cuid())
  orderCode             String      @unique // == Midtrans order_id
  customerId            String
  productId             String
  amountIdr             Int
  currency              String      @default("IDR")
  status                OrderStatus @default(PENDING)
  trackingId            String? // attribution / referral id (nullable)
  snapToken             String?
  snapRedirectUrl       String?
  midtransTransactionId String?
  paymentType           String?
  paidAt                DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  customer              Customer    @relation(fields: [customerId], references: [id])
  product               Product     @relation(fields: [productId], references: [id])
  delivery              Delivery?
  events                PaymentEvent[]
  challengeParticipant  ChallengeParticipant?

  @@index([status])
  @@index([trackingId])
}

model PaymentEvent {
  // immutable audit log of every notification
  id                String   @id @default(cuid())
  orderId           String
  transactionStatus String
  fraudStatus       String?
  statusCode        String?
  signatureValid    Boolean
  rawPayload        Json
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model Delivery {
  id            String         @id @default(cuid())
  orderId       String         @unique // one delivery per order => no double-send
  downloadToken String?        @unique // D16 (§25): protected e-book download link token (base64url, 128-bit)
  channel       String         @default("whatsapp")
  status        DeliveryStatus @default(PENDING)
  attempts      Int            @default(0)
  maxAttempts   Int            @default(5)
  nextRetryAt   DateTime?
  wahaMessageId String?
  lastError     String?
  sentAt        DateTime?
  // Email fallback (D14, §23): the e-book is also emailed when a WhatsApp send fails.
  // Idempotent — once emailFallbackSentAt is set, no further email is attempted.
  emailFallbackSentAt    DateTime?
  emailFallbackError     String?
  emailFallbackAttempts  Int       @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  order         Order          @relation(fields: [orderId], references: [id])
  items         DeliveryItem[]

  @@index([status, nextRetryAt])
}

model DeliveryItem {
  id            String         @id @default(cuid())
  deliveryId    String
  kind          String // "ebook" | "attachment"
  filePath      String // snapshot of the file at purchase time (relative to EBOOK_FILES_DIR)
  fileName      String // buyer-facing name sent over WAHA
  sortOrder     Int            @default(0) // 0 = e-book first, then attachments
  status        DeliveryStatus @default(PENDING)
  attempts      Int            @default(0)
  wahaMessageId String?
  lastError     String?
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  delivery      Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, status])
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  name         String
  passwordHash String    // "scrypt$<saltHex>$<hashHex>"
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // sha256 of the random token in the cookie
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AllowedOrigin {
  id        String   @id @default(cuid())
  origin    String   @unique // normalized "scheme://host[:port]" — CORS allowlist for /api/checkout
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateLimitConfig {
  id            String   @id @default("default") // singleton row
  enabled       Boolean  @default(true)
  maxRequests   Int      @default(10) // per IP per window on /api/checkout
  windowSeconds Int      @default(60)
  updatedAt     DateTime @updatedAt
}

// Active outbound/inbound WhatsApp engine selector (slice D15, §24). Singleton row.
model MessagingConfig {
  id        String   @id @default("default") // singleton row
  engine    String   @default("waha") // 'waha' | 'fonnte' — the single global active engine
  updatedAt DateTime @updatedAt
}

// ── Challenge / reward module (§21) ────────────────────────────────────
model Challenge {
  id                   String   @id @default(cuid())
  productId            String   @unique // one challenge per program (Product)
  isActive             Boolean  @default(false)
  startWindowDays      Int      @default(14)
  durationDays         Int      @default(90)
  finalProofWindowDays Int      @default(14)
  phases               Json // [{ name, focus, startDay, endDay }]
  videoMaxSeconds      Int      @default(30)
  videoMaxSizeMb       Int      @default(10)
  videoFormat          String   @default("mp4")
  rewardsText          String?
  winnerTiers          Json // [{ label, prize, count }]
  contactInfo          String?
  messageTemplates     Json // { triggerKey: "text" } — used by D12 automation
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  participants         ChallengeParticipant[]
}

enum ParticipantStatus {
  AWAITING_INITIAL // bought, awaiting the initial proof (auto-created on PAID) — D12
  PENDING_INITIAL_REVIEW
  RUNNING
  PENDING_FINAL_REVIEW
  COMPLETED
  DROPPED
}

model ChallengeParticipant {
  id               String            @id @default(cuid())
  challengeId      String
  customerId       String
  orderId          String            @unique // one entry per PAID order
  status           ParticipantStatus @default(PENDING_INITIAL_REVIEW)
  purchaseAt       DateTime // snapshot of order.paidAt (start-window anchor)
  startAt          DateTime? // = initial proof received date (challenge day 1)
  initialWeightKg  Float?
  finalSubmittedAt DateTime?
  finalWeightKg    Float?
  percentLoss      Float?
  dropReason       String? // "eliminated_initial" | "eliminated_final" | "disqualified" | free text
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  challenge        Challenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id])
  order            Order             @relation(fields: [orderId], references: [id])
  submissions      ChallengeSubmission[]
  reminders        ChallengeReminderLog[]

  @@index([challengeId, status])
}

model ChallengeReminderLog {
  id            String   @id @default(cuid())
  participantId String
  key           String // template/trigger key, e.g. "after_purchase", "h7", "day90"
  sentAt        DateTime @default(now())
  wahaMessageId String?
  error         String?
  participant   ChallengeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, key]) // each reminder sent at most once per participant (idempotent)
}

// ── WA Logs (slice D5, §20.13) ─────────────────────────────────────────
// Immutable audit log of every OUTBOUND WhatsApp send (e-book/attachment delivery +
// challenge reminders). Decoupled from the source rows (no FK) so the audit trail
// survives a delivery/participant delete. Written best-effort — logging never blocks a send.
enum WaLogStatus {
  SENT
  FAILED
}

model WaMessageLog {
  id             String      @id @default(cuid())
  category       String // "ebook" | "attachment" | "reminder"
  status         WaLogStatus
  chatId         String // WAHA recipient chatId ("…@c.us")
  toPhone        String? // normalized digits when known
  templateKey    String? // reminder/template trigger key (e.g. "after_purchase", "h7")
  fileName       String? // file sends — buyer-facing filename
  bodyPreview    String? // short snippet of the caption/text (truncated)
  wahaMessageId  String?
  error          String? // failure reason when status = FAILED
  orderId        String? // links (plain ids, no FK — durable audit)
  deliveryId     String? // delivery rows → enables Resend from the UI
  deliveryItemId String?
  participantId  String?
  productId      String? // for the program filter
  createdAt      DateTime    @default(now())

  @@index([createdAt])
  @@index([category, status])
  @@index([productId])
}

model ChallengeSubmission {
  id             String   @id @default(cuid())
  participantId  String
  kind           String // "initial" | "final"
  receivedAt     DateTime @default(now())
  fromNumber     String // sender WhatsApp (normalized digits)
  wahaMessageId  String?  @unique // dedupe inbound webhook deliveries (payload.id)
  mediaPath      String? // private path under CHALLENGE_MEDIA_DIR (never public/)
  mimeType       String?
  sizeBytes      Int?
  verifiedAt     DateTime?
  rejectedReason String?
  rawPayload     Json?
  participant    ChallengeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
}
